# Public frontend config only. Values prefixed with VITE_ are exposed to browsers.
# Local development default. Production can leave this empty to use /api and Vercel rewrites.
VITE_API_BASE_URL=

# Vercel build-time rewrite source. Keep this in Doppler prd and sync to Vercel.
# Examples:
# - 8.156.88.100
# - api.example.com
# - https://api.example.com
BACKEND_ORIGIN=
