# Doppler-managed placeholders only. Do not copy real secrets into this file.
APP_ENV=local
API_TIMEOUT_SECONDS=18
BACKEND_AGENT_PATH=backend_agent
ENABLE_AGENT_FALLBACK=true

# Values below are consumed by backend_agent when Doppler injects them.
DATABASE_URL=sqlite:///data/app.db
CHROMA_PATH=data/chroma
LLM_API_KEY=your_value_here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
ENABLE_LLM=false
ENABLE_VECTOR=true
ENABLE_GRAPH=true
ENABLE_RERANKER=false
RERANK_PROVIDER=heuristic
RERANK_MODEL=your_value_here
RERANK_BASE_URL=https://example.com/v1
RERANK_API_KEY=your_value_here
RERANK_TOP_N=50
SKIP_AGENT_REBUILD=false
RAW_DATA_SYNC_COMMAND=
PYTHON_BASE_IMAGE=m.daocloud.io/docker.io/library/python:3.12-slim
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn
